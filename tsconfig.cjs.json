{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "outDir": "./dist/cjs",
    "declaration": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.d.ts",
    "**/*.test.ts",
    "src/**/__tests__/**",
    "src/test",
    "src/index.browser.ts",
    "src/examples",
    "src/**/examples/**",
    "vitest.config.ts",
    "vitest.browser.config.ts",
    "rolldown.config.js",
    "benchmark.js"
  ]
}
