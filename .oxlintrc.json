{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript"],
  "options": {
    "typeAware": true
  },
  "ignorePatterns": ["scripts/**/*", "test/**/*", "dist/**/*", "**/*.generated.ts"],
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx}"],
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "args": "none",
            "ignoreRestSiblings": true,
            "caughtErrors": false,
            "ignoreClassWithStaticInitBlock": true,
            "reportUsedIgnorePattern": false,
            "reportVarsOnlyUsedAsTypes": false,
            "varsIgnorePattern": "^_"
          }
        ],
        "no-sparse-arrays": 0,
        "no-unsafe-finally": 2,
        "no-useless-escape": 2,
        "no-empty": 2,
        "no-case-declarations": 2,
        "no-async-promise-executor": 2,
        "curly": ["error", "all"],
        "no-return-assign": 2,
        "no-unneeded-ternary": 2,
        "yoda": 2,
        "no-debugger": 2,
        "no-var": 2,
        "prefer-const": 2,
        "no-eval": 2,
        "no-self-compare": 2,
        "no-template-curly-in-string": 2,
        "no-unreachable": 2,
        "no-constant-condition": 2,
        "no-throw-literal": 2,
        "eqeqeq": ["error", "smart"],
        "no-proto": 2,
        "no-constructor-return": 2,
        "no-new-wrappers": 2,
        "no-iterator": 2,
        "no-loss-of-precision": 2,
        "no-nonoctal-decimal-escape": 2,
        "no-unsafe-optional-chaining": 2,
        "no-unused-private-class-members": 2,
        "no-constant-binary-expression": 2,
        "no-object-constructor": 2,
        "no-dupe-class-members": 2,
        "no-this-before-super": 2,
        "require-yield": 2,
        "no-prototype-builtins": 2,
        "no-regex-spaces": 2,
        "no-sequences": 2,
        "prefer-rest-params": 2,
        "prefer-spread": 2,
        "no-with": 2,
        "no-labels": 2,

        "typescript/no-explicit-any": 0,
        "typescript/no-duplicate-enum-values": 2,
        "typescript/ban-ts-comment": 2,
        "typescript/no-unsafe-function-type": 2,
        "typescript/no-unused-expressions": 2,
        "typescript/no-empty-interface": 2,
        "typescript/no-non-null-asserted-optional-chain": 2,
        "typescript/no-empty-object-type": 2,
        "typescript/consistent-type-imports": 2,
        "typescript/consistent-type-exports": 2,
        "typescript/no-require-imports": "error",
        "typescript/prefer-ts-expect-error": 2,
        "typescript/no-this-alias": 2,
        "typescript/prefer-as-const": 2,
        "typescript/no-unnecessary-boolean-literal-compare": 2,
        "typescript/no-extraneous-class": 2,
        "typescript/no-useless-constructor": 2,
        "typescript/no-misused-spread": 0,
        "typescript/no-useless-default-assignment": 2,

        "typescript/await-thenable": "error",
        "typescript/no-redundant-type-constituents": "error",
        "typescript/no-floating-promises": 0,
        "typescript/no-base-to-string": 0,
        "typescript/unbound-method": 0,
        "typescript/restrict-template-expressions": 0,
        "typescript/no-duplicate-type-constituents": 2,
        "typescript/no-array-delete": 2,
        "typescript/no-implied-eval": 2,
        "typescript/require-array-sort-compare": 2,

        "import/no-cycle": [2, { "ignoreExternal": true }],
        "import/no-duplicates": "error",
        "import/no-self-import": 2,
        "import/no-default-export": 2
      }
    }
  ]
}
