{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript"],
  "options": {
    "typeAware": true
  },
  "ignorePatterns": ["scripts/**/*", "test/**/*", "dist/**/*"],
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx}"],
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "args": "none",
            "ignoreRestSiblings": true,
            "caughtErrors": false,
            "ignoreClassWithStaticInitBlock": true,
            "reportUsedIgnorePattern": false,
            "reportVarsOnlyUsedAsTypes": false,
            "varsIgnorePattern": "^_"
          }
        ],
        "no-sparse-arrays": 0,
        "no-unsafe-finally": 2,
        "no-useless-escape": 0,
        "no-empty": 0,
        "no-case-declarations": 0,
        "no-async-promise-executor": 0,
        "curly": ["error", "all"],
        // Wait to enable
        "no-return-assign": 0,
        "no-unneeded-ternary": 2,
        "yoda": 2,

        "typescript/no-explicit-any": 0,
        "typescript/no-duplicate-enum-values": 0,
        "typescript/ban-ts-comment": 0,
        "typescript/ban-types": 0,
        "typescript/no-unsafe-function-type": 0,
        "typescript/no-unused-expressions": 0,
        "typescript/no-empty-interface": 2,
        "typescript/no-non-null-asserted-optional-chain": 2,
        "typescript/no-empty-object-type": 2,
        "typescript/consistent-type-imports": 2,
        "typescript/consistent-type-exports": 2,
        "typescript/no-require-imports": "error",

        // Type-aware rules (via tsgolint)
        "typescript/await-thenable": "error",
        "typescript/no-redundant-type-constituents": "error",
        // Wait to enable, too many hits
        "typescript/no-floating-promises": 0,
        "typescript/no-base-to-string": 0,
        "typescript/unbound-method": 0,
        "typescript/restrict-template-expressions": 0,
        "typescript/no-duplicate-type-constituents": 0,
        "typescript/no-array-delete": 0,
        "typescript/no-implied-eval": 0,
        "typescript/require-array-sort-compare": 0,

        "import/no-cycle": [2, { "ignoreExternal": true }]
        // "import/no-duplicates": "error"
      }
    }
  ]
}
