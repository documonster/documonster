#!/usr/bin/env sh
# Pre-commit hook: format, lint, and type-check the whole project.
#
# 1. Run `pnpm format` to auto-fix formatting across the project.
# 2. Re-stage any originally-staged file that oxfmt modified, so the
#    formatted content is included in the current commit. Files that were
#    not part of this commit are intentionally NOT re-added, to keep the
#    commit scope unchanged.
# 3. Run `pnpm lint` and `pnpm type` in parallel. If either fails, abort
#    the commit so broken code never lands on a branch.

set -e

echo "[pre-commit] 1/3 formatting project (pnpm format)…"
pnpm -s format

# Collect the list of files that were staged when the commit started.
# `--cached --name-only --diff-filter=ACMR` = Added / Copied / Modified /
# Renamed files that are currently in the index. Deleted files are skipped
# (nothing to re-add). Binary/non-text files are safe — oxfmt ignores them.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -n "$STAGED_FILES" ]; then
  # Re-add only staged files whose working-tree copy differs from the
  # index copy (i.e. oxfmt actually changed them). `git diff --name-only`
  # (no --cached) compares working tree vs index; intersecting with
  # STAGED_FILES keeps the commit scope unchanged.
  FORMATTED_STAGED=$(git diff --name-only -- $STAGED_FILES)
  if [ -n "$FORMATTED_STAGED" ]; then
    echo "[pre-commit]   re-adding formatted files:"
    echo "$FORMATTED_STAGED" | sed 's/^/    /'
    # shellcheck disable=SC2086  # intentional word-splitting on newlines
    git add $FORMATTED_STAGED
  fi
fi

echo "[pre-commit] 2/3 running lint + type in parallel…"
# Reuse the concurrently binary (already a devDependency). Using
# `pnpm exec` avoids hard-coding the path; both commands run in parallel
# and the first failure fails the whole step.
pnpm exec concurrently --raw --kill-others-on-fail \
  "pnpm -s lint" \
  "pnpm -s type"

echo "[pre-commit] 3/3 done — proceeding with commit."
