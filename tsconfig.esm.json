{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": false,
    "stripInternal": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.d.ts",
    "**/*.test.ts",
    "src/**/__tests__/**",
    "src/test",
    "src/examples",
    "src/**/examples/**",
    "vitest.config.ts",
    "vitest.browser.config.ts",
    "rolldown.config.js",
    "benchmark.js"
  ]
}
