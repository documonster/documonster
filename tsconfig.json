{
  "compilerOptions": {
    "paths": {
      "@archive": ["./src/modules/archive/index.ts"],
      "@excel": ["./src/modules/excel/index.ts"],
      "@excel/*": ["./src/modules/excel/*"],
      "@archive/*": ["./src/modules/archive/*"],
      "@stream": ["./src/modules/stream/index.ts"],
      "@stream/*": ["./src/modules/stream/*"],
      "@csv": ["./src/modules/csv/index.ts"],
      "@csv/*": ["./src/modules/csv/*"],
      "@markdown": ["./src/modules/markdown/index.ts"],
      "@markdown/*": ["./src/modules/markdown/*"],
      "@xml": ["./src/modules/xml/index.ts"],
      "@xml/*": ["./src/modules/xml/*"],
      "@word": ["./src/modules/word/index.ts"],
      "@word/*": ["./src/modules/word/*"],
      "@pdf": ["./src/modules/pdf/index.ts"],
      "@pdf/*": ["./src/modules/pdf/*"],
      "@formula": ["./src/modules/formula/index.ts"],
      "@formula/*": ["./src/modules/formula/*"],
      "@utils/*": ["./src/utils/*"],
      "@test/*": ["./src/test/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals", "node"]
  },
  "exclude": [
    "node_modules",
    "benchmark",
    "tmp",
    "dist",
    "out",
    "scripts/**",
    "src/modules/csv/worker/worker-script.ts"
  ]
}
