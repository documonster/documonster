{
  "compilerOptions": {
    "paths": {
      "@archive": ["./src/modules/archive/index.ts"],
      "@excel/*": ["./src/modules/excel/*"],
      "@archive/*": ["./src/modules/archive/*"],
      "@stream": ["./src/modules/stream/index.ts"],
      "@stream/*": ["./src/modules/stream/*"],
      "@csv/*": ["./src/modules/csv/*"],
      "@pdf": ["./src/modules/pdf/index.ts"],
      "@pdf/*": ["./src/modules/pdf/*"],
      "@utils/*": ["./src/utils/*"],
      "@test/*": ["./src/test/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "lib": ["ESNext", "DOM"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals", "node"]
  },
  "exclude": [
    "node_modules",
    "benchmark",
    "tmp",
    "dist",
    "out",
    "scripts/benchmark*.ts",
    "src/modules/csv/worker/worker-script.ts"
  ]
}
