# EditorConfig: https://EditorConfig.org

root = true

# Baseline for all files (charset, trailing whitespace)
# oxfmt handles JS/TS/JSON formatting — these cover everything else.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
